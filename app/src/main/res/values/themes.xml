<resources>
    <style name="Theme.MoneyMate" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_dark</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorSecondaryVariant">@color/color_secondary_container</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surface -->
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/color_on_surface_secondary</item>
        <item name="android:colorBackground">@color/color_background</item>
        <item name="android:textColorPrimary">@color/color_on_surface</item>
        <item name="android:textColorSecondary">@color/color_on_surface_secondary</item>

        <!-- Controls -->
        <item name="colorControlHighlight">@color/color_ripple</item>
        <item name="android:textColorHighlight">@color/color_ripple</item>
        <item name="android:statusBarColor">@color/color_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/color_surface</item>

        <!-- OPPO compatibility -->
        <item name="viewInflaterClass">androidx.appcompat.app.AppCompatViewInflater</item>
        <item name="android:textColorHighlight">@color/color_ripple</item>

        <!-- Text appearances -->
        <item name="textAppearanceBody1">@style/TextAppearance.MaterialComponents.Body1</item>
        <item name="textAppearanceBody2">@style/TextAppearance.MaterialComponents.Body2</item>
        <item name="textAppearanceCaption">@style/TextAppearance.MaterialComponents.Caption</item>
        <item name="textAppearanceButton">@style/TextAppearance.MaterialComponents.Button</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.MaterialComponents.Subtitle1</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.MaterialComponents.Subtitle2</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.MaterialComponents.Headline6</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.MaterialComponents.Body2</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.MaterialComponents.Caption</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.MaterialComponents.Caption</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.MaterialComponents.Caption</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.MaterialComponents.Subtitle1</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.MaterialComponents.Subtitle2</item>

        <!-- Bottom Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.MoneyMate.BottomNavigation</item>
    </style>

    <style name="Widget.MoneyMate.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/color_surface</item>
        <item name="itemIconTint">@color/selector_bottom_nav</item>
        <item name="itemTextColor">@color/selector_bottom_nav</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.MoneyMate.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/color_card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/color_card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.MoneyMate.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Widget.MoneyMate.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/color_primary</item>
    </style>
</resources>
